{
  "name": "koinara-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "setup": "tsx src/setup/setup.ts",
    "node": "tsx src/index.ts",
    "node:once": "tsx src/index.ts --once",
    "doctor": "tsx src/doctor.ts",
    "status": "tsx src/status.ts",
    "logs": "tsx src/index.ts",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
