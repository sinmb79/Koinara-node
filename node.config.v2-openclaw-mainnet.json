{
  "networkProfile": "mainnet",
  "selectionMode": "priority-failover",
  "enabledNetworks": [
    "worldland"
  ],
  "pollIntervalMs": 10000,
  "manifestRoots": [
    "../worldland/.koinara-worldland-v2/network"
  ],
  "receiptRoots": [
    "../worldland/.koinara-worldland-v2/network"
  ],
  "artifactOutputDir": "./.koinara-node-v2-openclaw/artifacts",
  "provider": {
    "backend": "openclaw",
    "supportedJobTypes": [
      "Simple"
    ],
    "openclaw": {
      "agent": "main",
      "local": true,
      "thinking": "low",
      "timeoutSeconds": 120
    }
  },
  "verifier": {
    "supportedJobTypes": [
      "Simple",
      "General",
      "Collective"
    ],
    "supportedSchemaHashes": []
  }
}
